# Firebase Admin SDK service-account credential
GCP_CERT_PATH=./credentials/your-service-account.json
GCP_PROJECT_ID=your-gcp-project-id

# Discord webhook (optional integration)
DISCORD_WEBHOOK=

# LINE Login (admin auth) — register a LINE Login channel and paste credentials here.
# https://developers.line.biz/console/
NUXT_LINE_CHANNEL_ID=
NUXT_LINE_CHANNEL_SECRET=
# Must match a Callback URL registered in the LINE channel.
NUXT_LINE_CALLBACK_URL=http://localhost:3000/admin/auth/callback
# Comma-separated list of LINE user IDs allowed into /admin.
NUXT_LINE_ADMIN_USER_IDS=

# Secret used to sign session cookies. Generate with: openssl rand -hex 32
NUXT_SESSION_SECRET=
